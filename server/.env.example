# ==============================
# StudyShare Server — Environment Variables
# Copy this to .env and fill in your values
# ==============================

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/studyshare?schema=public"

# JWT — generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# File Uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=200

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ==============================
# AI Configuration (Groq — FREE)
# Sign up at https://console.groq.com → API Keys
# ==============================
AI_ENABLED=false
GROQ_API_KEY=""

# ==============================
# File Storage — Backblaze B2 (S3-compatible, FREE 10GB)
# Sign up at https://www.backblaze.com/b2/cloud-storage.html
# Create a bucket → Application Keys → copy values below
# ==============================
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-b2-key-id"
AWS_SECRET_ACCESS_KEY="your-b2-application-key"
AWS_ENDPOINT_URL="https://s3.us-east-005.backblazeb2.com"
AWS_S3_BUCKET_NAME="studyshare-uploads"

# For local dev only (MinIO via Docker):
# AWS_ACCESS_KEY_ID="test"
# AWS_SECRET_ACCESS_KEY="testpassword"
# AWS_ENDPOINT_URL="http://127.0.0.1:9000"
